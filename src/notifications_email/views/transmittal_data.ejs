<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RFI Inspection Notification</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f6f8fa;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        .email-container {
            max-width: 600px;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            border: 1px solid #ddd;
        }

        .header {
            text-align: center;
            padding-bottom: 15px;
            /* border-bottom: 1px solid #eee; */
        }

        .logo {
            width: 180px;
            margin-bottom: 10px;
        }

        .title {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 15px;
            margin-top: 10px;
            color: #004aad;
            text-align: center;
        }

        .status-approved {
            color: #0a8a0a;
            font-weight: bold;
        }

        .status-rejected {
            color: #d60000;
            font-weight: bold;
        }


        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            font-size: 14px;
        }

        table th,
        table td {
            border: 1px solid #e1e6f5;
            padding: 8px;
            text-align: left;
        }

        table th {
            background-color: #f1f5ff;
            width: 35%;
        }

        .footer {
            font-size: 12px;
            margin-top: 25px;
            text-align: center;
            color: #777;
            border-top: 1px solid #eee;
            padding-top: 15px;
        }
    </style>
</head>

<body>
    <div class="email-container">

        <!-- HEADER -->
        <div class="header">
            <img class="logo"
                src="https://i.ibb.co.com/3YRFHrNF/mechanical-completion.png"
                alt="Company Logo" />
        </div>

        <!-- TITLE -->
        <div class="title">
            MC - RFI Transmittal To Client : <%= submission_id %>
        </div>

        <!-- CONTENT -->
        <p>
            This is to inform you that the following inspection report has been
            <strong class="<%= status === 'Transmittal To Qc' ? 'status-approved' : 'status-rejected' %>">
                <%= status %>
            </strong>.
        </p>

        <table>
            <tr>
                <th>Submissio No </th>
                <td><%= submission_id %></td>
            </tr>
            <tr>
                <th>System</th>
                <td><%= system %></td>
            </tr>
            <tr>
                <th>Subsystem</th>
                <td><%= subsystem %></td>
            </tr>
            <!-- <tr>
                <th>Invitation Type</th>
                <td><%= status_invitation %></td>
            </tr> -->

            <tr>
                <th>Inspect Authority</th>
                <td><%= legend_inspection_auth %></td>
            </tr>
            <tr>
                <th>Status label</th>
                <td><%= status %></td>
            </tr>
            <tr>
                <th>Inspection Date</th>
                <td class="time"><%= inspectionDate %></td>
            </tr>

        </table>

        <!-- FOOTER -->
        <div class="footer">
            Regards,<br />
            <strong>MC System</strong><br />
            (Auto Notification System)
            <br><br>
            <em>This email was auto-generated by the system. Please do not reply.</em>
        </div>

    </div>
</body>

</html>
